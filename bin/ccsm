#!/usr/bin/env node

"use strict";

/**
 * ccsm — Claude Code Session Manager
 * ====================================
 * CLI tool and interactive TUI for listing, previewing, deleting, and
 * auto-cleaning Claude Code session files stored under PROJECTS_DIR.
 *
 * Architecture
 * ------------
 * Subcommands route to CLI handlers that emit JSON to stdout and exit.
 * When invoked without a subcommand and a TTY is present, the script
 * opens /dev/tty directly so it works even when stdout is piped, then
 * enters a full-screen TUI with session list, message preview,
 * search/filter, and delete confirmation.
 *
 * Key segments:
 *   Configuration   — flag parsing, PROJECTS_DIR resolution
 *   Formatters      — formatSize
 *   Path utilities  — projectFromDirName, shortenCwd
 *   Filesystem      — dirHasNoFiles, deleteSessionFiles
 *   Session data    — scanSessions, listSessions, previewSession,
 *                     deleteSession, parseMessages
 *   Detection       — isAutoGenerated
 *   Filtering       — applyFilterStandalone
 *   TTY             — hasTty
 *   Terminal ctrl   — enterAltScreen, exitAltScreen, moveTo,
 *                     clearLine, style, truncate
 *   Renderers       — renderList, renderPreview, renderDeleteConfirm,
 *                     renderEmpty, renderNoMatches
 *   Interactive     — runInteractive (TUI entry point)
 *   CLI handlers    — handleList, handlePreview, handleDelete,
 *                     handleCleanAuto
 *   Bootstrap       — main(), require.main guard
 *
 * Output examples
 * ---------------
 *   ccsm --list
 *   → {"mode":"cli","sessions":[{"id":"...","project":"~/src",...}]}
 *
 *   ccsm --preview abc123
 *   → {"mode":"cli","sessionId":"abc123","messages":[...]}
 *
 *   ccsm --delete abc123
 *   → {"mode":"cli","deleted":"abc123","remaining":4}
 *
 *   ccsm --clean-auto
 *   → {"mode":"cli","cleaned":2,"remaining":5,"deleted":["a","b"]}
 *
 * Side effects
 * ------------
 * deleteSession / handleDelete / handleCleanAuto remove .jsonl files and
 * their associated subdirectories. Project folders that become empty after
 * deletion are also removed.
 */

const fs = require("fs");
const os = require("os");
const path = require("path");

// ─────────────────────────────────────────────
// Configuration & argument parsing
// ─────────────────────────────────────────────

const argv = process.argv.slice(2);

function getFlag(flag) {
  return argv.indexOf(flag) !== -1;
}

function getFlagValue(flag) {
  const idx = argv.indexOf(flag);
  return idx !== -1 && argv[idx + 1] !== undefined ? argv[idx + 1] : null;
}

const MODE_LIST = getFlag("--list");
const MODE_PREVIEW = getFlag("--preview");
const MODE_DELETE = getFlag("--delete");
const MODE_CLEAN_AUTO = getFlag("--clean-auto");
const PREVIEW_ID = getFlagValue("--preview");
const DELETE_ID = getFlagValue("--delete");
const PROJECTS_DIR =
  getFlagValue("--projects-dir") ||
  (process.env.CLAUDE_CONFIG_DIR
    ? path.join(process.env.CLAUDE_CONFIG_DIR, "projects")
    : null) ||
  path.join(os.homedir(), ".claude", "projects");

// ─────────────────────────────────────────────
// Formatters
// ─────────────────────────────────────────────

/**
 * Format a byte count into a human-readable string.
 * <1024 → "{n}B", <1048576 → "{n}K", >=1048576 → "{n.n}M"
 *
 * @param {number} bytes
 * @returns {string}
 */
function formatSize(bytes) {
  if (bytes < 1024) return `${bytes}B`;
  if (bytes < 1048576) return `${Math.floor(bytes / 1024)}K`;
  return `${(bytes / 1048576).toFixed(1)}M`;
}

// ─────────────────────────────────────────────
// Path utilities
// ─────────────────────────────────────────────

/**
 * Derive a project label from a Claude Code project directory name.
 *
 * Claude Code encodes the project path into the directory name as
 * "-Users-<username>-Some-Path". This reverses the encoding back to
 * "~/Some/Path" for display. Falls back to the raw name if the
 * encoding pattern is not recognized.
 *
 * @param {string} dirName
 * @returns {string}
 */
function projectFromDirName(dirName) {
  const match = dirName.match(/^-Users-[^-]+(-(.+))?$/);
  if (!match) return dirName;
  return match[2] ? "~/" + match[2].replace(/-/g, "/") : "~";
}

/**
 * Shorten an absolute path by replacing the home directory prefix with "~".
 *
 * @param {string} cwdValue
 * @param {string} [homeDir] - Defaults to os.homedir()
 * @returns {string}
 */
function shortenCwd(cwdValue, homeDir) {
  const home = homeDir || os.homedir();
  if (cwdValue === home) return "~";
  if (cwdValue.startsWith(home + "/")) return "~" + cwdValue.slice(home.length);
  return cwdValue;
}

// ─────────────────────────────────────────────
// Filesystem helpers
// ─────────────────────────────────────────────

/**
 * Returns true if dirPath contains no files at any depth.
 *
 * Used to decide whether a project folder is safe to remove after its
 * last session file is deleted.
 *
 * @param {string} dirPath
 * @returns {boolean}
 */
function dirHasNoFiles(dirPath) {
  let entries;
  try {
    entries = fs.readdirSync(dirPath, { withFileTypes: true });
  } catch (_) {
    return false;
  }
  for (const entry of entries) {
    if (entry.isFile()) return false;
    if (entry.isDirectory() && !dirHasNoFiles(path.join(dirPath, entry.name))) {
      return false;
    }
  }
  return true;
}

/**
 * Delete a session file, its companion subdirectory, and the parent
 * project folder when it becomes empty.
 *
 * Claude Code places sidecar data for a session in a subdirectory with
 * the same stem as the .jsonl file. Both must go together.
 *
 * @param {object} session
 */
function deleteSessionFiles(session) {
  fs.unlinkSync(session.filePath);

  const projectDir = path.dirname(session.filePath);
  const sidecar = path.join(projectDir, session.sessionId);
  if (fs.existsSync(sidecar)) {
    fs.rmSync(sidecar, { recursive: true, force: true });
  }

  const isProjectRoot = path.resolve(projectDir) === path.resolve(PROJECTS_DIR);
  if (!isProjectRoot && fs.existsSync(projectDir) && dirHasNoFiles(projectDir)) {
    fs.rmSync(projectDir, { recursive: true, force: true });
  }
}

// ─────────────────────────────────────────────
// Session scanning
// ─────────────────────────────────────────────

/**
 * Extract the project path for a session file.
 *
 * Claude Code records cwd in the first few JSONL entries. Reading cwd
 * directly is more reliable than decoding the directory name, which only
 * works for macOS-style paths.
 *
 * @param {string[]} lines - Raw JSONL lines from the session file
 * @param {string} dirName - Fallback: the project directory name
 * @param {string} homeDir
 * @returns {string}
 */
function extractProject(lines, dirName, homeDir) {
  const scanLimit = Math.min(lines.length, 10);
  for (let i = 0; i < scanLimit; i++) {
    try {
      const parsed = JSON.parse(lines[i]);
      if (parsed.cwd) return shortenCwd(parsed.cwd, homeDir);
    } catch (_) {
      // skip malformed lines
    }
  }
  return projectFromDirName(dirName);
}

/**
 * Extract user message count, first message text, and custom title
 * from a session's JSONL lines.
 *
 * Custom titles come from /rename entries; the last one wins because
 * the user may rename a session multiple times.
 *
 * @param {string[]} lines
 * @returns {{ messageCount: number, firstMessage: string, customTitle: string }}
 */
function extractMessageMeta(lines) {
  let messageCount = 0;
  let firstMessage = "";
  let customTitle = "";

  for (const line of lines) {
    try {
      const parsed = JSON.parse(line);

      if (parsed.type === "custom-title" && parsed.customTitle) {
        customTitle = parsed.customTitle;
        continue;
      }

      if (parsed.type !== "user" || !parsed.message) continue;

      messageCount++;
      if (firstMessage) continue;

      const content = parsed.message.content;
      if (typeof content === "string") {
        firstMessage = content;
      } else if (Array.isArray(content)) {
        const block = content.find(
          (b) => b.type === "text" && typeof b.text === "string",
        );
        if (block) firstMessage = block.text;
      }
      if (firstMessage.length > 80) firstMessage = firstMessage.slice(0, 80);
    } catch (_) {
      // skip malformed lines
    }
  }

  return { messageCount, firstMessage, customTitle };
}

/**
 * Scan projectsDir for session files and return rich metadata for each.
 *
 * Skips agent sessions (prefixed "agent-") because they are internal
 * tool orchestration artifacts, not user conversations. Skips empty
 * files because they indicate an aborted or in-progress write.
 *
 * @param {string} projectsDir
 * @param {object} [options]
 * @param {string} [options.homeDir] - Override os.homedir() for testing
 * @returns {{
 *   sessionId: string,
 *   project: string,
 *   modified: Date,
 *   size: number,
 *   messageCount: number,
 *   firstMessage: string,
 *   customTitle: string,
 *   filePath: string
 * }[]}
 */
function scanSessions(projectsDir, options) {
  const homeDir = (options && options.homeDir) || os.homedir();

  if (!fs.existsSync(projectsDir)) return [];

  const subdirs = fs
    .readdirSync(projectsDir, { withFileTypes: true })
    .filter((d) => d.isDirectory())
    .map((d) => d.name);

  const results = [];

  for (const dirName of subdirs) {
    const dirPath = path.join(projectsDir, dirName);
    let entries;
    try {
      entries = fs.readdirSync(dirPath, { withFileTypes: true });
    } catch (_) {
      continue;
    }

    for (const entry of entries) {
      if (!entry.isFile() || !entry.name.endsWith(".jsonl")) continue;

      const sessionId = entry.name.replace(/\.jsonl$/, "");
      if (sessionId.startsWith("agent-")) continue;

      const filePath = path.join(dirPath, entry.name);

      let stat;
      try {
        stat = fs.statSync(filePath);
      } catch (_) {
        continue;
      }

      if (stat.size === 0) continue;

      let raw;
      try {
        raw = fs.readFileSync(filePath, "utf8");
      } catch (_) {
        continue;
      }

      const lines = raw.split("\n").filter((l) => l.trim() !== "");
      const project = extractProject(lines, dirName, homeDir);
      const { messageCount, firstMessage, customTitle } =
        extractMessageMeta(lines);

      results.push({
        sessionId,
        project,
        modified: stat.mtime,
        size: stat.size,
        messageCount,
        firstMessage,
        customTitle,
        filePath,
      });
    }
  }

  results.sort((a, b) => b.modified - a.modified);
  return results;
}

/**
 * Return a flat list of session objects found under PROJECTS_DIR.
 * Wraps scanSessions for backward compat.
 *
 * @returns {{ id: string, project: string, filePath: string }[]}
 */
function listSessions() {
  return scanSessions(PROJECTS_DIR).map((s) => ({
    id: s.sessionId,
    project: s.project,
    filePath: s.filePath,
  }));
}

/**
 * Return the raw content of a session file by id.
 *
 * @param {string} id
 * @returns {{ ok: true, content: string } | { ok: false, error: string }}
 */
function previewSession(id) {
  const session = listSessions().find((s) => s.id === id);
  if (!session) return { ok: false, error: `Session not found: ${id}` };
  try {
    return { ok: true, content: fs.readFileSync(session.filePath, "utf8") };
  } catch (err) {
    return { ok: false, error: err.message };
  }
}

/**
 * Delete a session file by id.
 *
 * @param {string} id
 * @returns {{ ok: true, filePath: string } | { ok: false, error: string }}
 */
function deleteSession(id) {
  const session = listSessions().find((s) => s.id === id);
  if (!session) return { ok: false, error: `Session not found: ${id}` };
  try {
    fs.unlinkSync(session.filePath);
    return { ok: true, filePath: session.filePath };
  } catch (err) {
    return { ok: false, error: err.message };
  }
}

/**
 * Parse a JSONL session file and return the first 20 user/assistant
 * messages as structured objects.
 *
 * - type:"user"      → extract text from message.content (string or array)
 * - type:"assistant" → join all text blocks; skip tool_use blocks
 *
 * The entry-level timestamp is used for both roles.
 *
 * @param {string} filePath
 * @returns {{ role: string, timestamp: string, text: string }[]}
 */
function parseMessages(filePath) {
  let raw;
  try {
    raw = fs.readFileSync(filePath, "utf8");
  } catch (_) {
    return [];
  }

  const lines = raw.split("\n").filter((l) => l.trim() !== "");
  const messages = [];

  for (const line of lines) {
    if (messages.length >= 20) break;

    let entry;
    try {
      entry = JSON.parse(line);
    } catch (_) {
      continue;
    }

    if (entry.type === "user" && entry.message) {
      const content = entry.message.content;
      let text = "";
      if (typeof content === "string") {
        text = content;
      } else if (Array.isArray(content)) {
        const block = content.find(
          (b) => b.type === "text" && typeof b.text === "string",
        );
        if (block) text = block.text;
      }
      if (text) messages.push({ role: "user", timestamp: entry.timestamp || "", text });
      continue;
    }

    if (entry.type === "assistant" && entry.message) {
      const content = entry.message.content;
      if (!Array.isArray(content)) continue;
      const text = content
        .filter((b) => b.type === "text" && typeof b.text === "string")
        .map((b) => b.text)
        .join("");
      if (text) messages.push({ role: "assistant", timestamp: entry.timestamp || "", text });
    }
  }

  return messages;
}

// ─────────────────────────────────────────────
// Auto-generated detection
// ─────────────────────────────────────────────

/**
 * Return true if a session was auto-generated by a slash command rather
 * than a real user conversation.
 *
 * Claude Code wraps /exit, /clear, and similar commands in a
 * <local-command-caveat> block. These sessions accumulate silently and
 * are safe to bulk-delete.
 *
 * @param {object} session - Session object from scanSessions
 * @returns {boolean}
 */
function isAutoGenerated(session) {
  const text = session.firstMessage || "";
  return (
    text.includes("<local-command-caveat>") ||
    text.includes("<command-name>/exit</command-name>") ||
    text.includes("<command-name>/clear</command-name>")
  );
}

// ─────────────────────────────────────────────
// Filtering
// ─────────────────────────────────────────────

/**
 * Apply a filter mode and optional search text to a sessions array.
 *
 * Separated from runInteractive so tests can exercise filtering logic
 * without spinning up a TUI.
 *
 * @param {object[]} sessions        - Full sessions array (from scanSessions)
 * @param {string[]} filterModes     - e.g. ['all', 'project:~/Desktop', 'small', 'old']
 * @param {number}   filterModeIndex - Index into filterModes
 * @param {string}   searchText      - Current search query (empty = no search)
 * @returns {{ filtered: object[], filterLabel: string }}
 */
function applyFilterStandalone(sessions, filterModes, filterModeIndex, searchText) {
  let result = [...sessions];

  if (searchText) {
    const q = searchText.toLowerCase();
    result = result.filter(
      (s) =>
        s.firstMessage.toLowerCase().includes(q) ||
        s.project.toLowerCase().includes(q) ||
        (s.customTitle && s.customTitle.toLowerCase().includes(q)),
    );
  }

  const mode = filterModes[filterModeIndex];
  if (mode.startsWith("project:")) {
    result = result.filter((s) => s.project === mode.slice(8));
  } else if (mode === "small") {
    result = result.filter((s) => s.size < 100 * 1024);
  } else if (mode === "old") {
    const threshold = Date.now() - 30 * 24 * 60 * 60 * 1000;
    result = result.filter((s) => s.modified.getTime() < threshold);
  }

  let filterLabel;
  if (searchText) {
    filterLabel = `Search: ${searchText}█`;
  } else if (mode === "all") {
    filterLabel = `Sessions (${result.length})`;
  } else if (mode.startsWith("project:")) {
    filterLabel = `Sessions (${result.length}) › ${mode.slice(8)}`;
  } else if (mode === "small") {
    filterLabel = `Sessions (${result.length}) › < 100K`;
  } else {
    filterLabel = `Sessions (${result.length}) › > 30 days`;
  }

  return { filtered: result, filterLabel };
}

// ─────────────────────────────────────────────
// TTY detection
// ─────────────────────────────────────────────

/**
 * Return true if /dev/tty can be opened for reading and writing.
 *
 * Checking /dev/tty rather than process.stdout.isTTY lets the tool
 * render its TUI even when stdout is redirected.
 *
 * @returns {boolean}
 */
function hasTty() {
  try {
    const fd = fs.openSync("/dev/tty", "r+");
    fs.closeSync(fd);
    return true;
  } catch (_) {
    return false;
  }
}

// ─────────────────────────────────────────────
// Terminal control helpers
// ─────────────────────────────────────────────

/**
 * Switch to the alternate screen buffer and hide the cursor.
 * @param {import('tty').WriteStream} tty
 */
function enterAltScreen(tty) {
  tty.write("\x1b[?1049h\x1b[?25l\x1b[H\x1b[2J");
}

/**
 * Restore the primary screen buffer and show the cursor.
 * @param {import('tty').WriteStream} tty
 */
function exitAltScreen(tty) {
  tty.write("\x1b[?1049l\x1b[?25h");
}

/**
 * Move the cursor to the given 1-based row and column.
 * @param {import('tty').WriteStream} tty
 * @param {number} row
 * @param {number} col
 */
function moveTo(tty, row, col) {
  tty.write(`\x1b[${row};${col}H`);
}

/**
 * Erase from the cursor to the end of the current line.
 * @param {import('tty').WriteStream} tty
 */
function clearLine(tty) {
  tty.write("\x1b[K");
}

/**
 * Wrap text in ANSI SGR codes and reset afterwards.
 * @param {string} text
 * @param {string} codes  e.g. "1;7" for bold+reverse
 * @returns {string}
 */
function style(text, codes) {
  return `\x1b[${codes}m${text}\x1b[0m`;
}

/**
 * Truncate text to maxWidth characters, appending '…' if truncated.
 * @param {string} text
 * @param {number} maxWidth
 * @returns {string}
 */
function truncate(text, maxWidth) {
  return text.length > maxWidth ? text.slice(0, maxWidth - 1) + "…" : text;
}

// ─────────────────────────────────────────────
// Renderers
// ─────────────────────────────────────────────

/**
 * Render the full-screen session list.
 *
 * @param {import('tty').WriteStream} tty
 * @param {{
 *   sessions: object[],
 *   filtered: object[],
 *   cursor: number,
 *   scrollOffset: number,
 *   filterLabel: string,
 *   termWidth: number,
 *   termHeight: number
 * }} state
 */
function renderList(tty, state) {
  const { filtered, cursor, scrollOffset, filterLabel, termWidth, termHeight } = state;
  const W = termWidth;
  const H = termHeight;

  tty.write("\x1b[H\x1b[2J");

  const inSearch = filterLabel.includes("Search:");
  const rightHint = inSearch ? "" : "Type to search...";
  const leftPart = truncate(filterLabel, W);
  moveTo(tty, 1, 1);
  clearLine(tty);
  if (rightHint) {
    const padding = Math.max(0, W - leftPart.length - rightHint.length);
    tty.write(leftPart + " ".repeat(padding) + style(rightHint, "2"));
  } else {
    tty.write(leftPart);
  }

  moveTo(tty, 2, 1);
  clearLine(tty);
  tty.write("─".repeat(W));

  const viewportSize = Math.floor((H - 4) / 2);
  const visibleSessions = filtered.slice(scrollOffset, scrollOffset + viewportSize);

  for (let i = 0; i < viewportSize; i++) {
    const session = visibleSessions[i];
    const metaRow = 3 + i * 2;
    const msgRow = 4 + i * 2;

    moveTo(tty, metaRow, 1);
    clearLine(tty);
    moveTo(tty, msgRow, 1);
    clearLine(tty);

    if (!session) continue;

    const isActive = scrollOffset + i === cursor;
    const d = session.modified instanceof Date ? session.modified : new Date(session.modified);
    const dateStr = `${String(d.getMonth() + 1).padStart(2, "0")}-${String(d.getDate()).padStart(2, "0")}`;
    const metaBase = `${isActive ? "► " : "  "}${dateStr}  ${formatSize(session.size)}  ${session.messageCount}msg  `;
    const projectAvail = Math.max(1, W - metaBase.length);
    const metaLine = `${metaBase}${style(truncate(session.project, projectAvail), "36")}`;

    moveTo(tty, metaRow, 1);
    clearLine(tty);
    tty.write(isActive ? style(metaLine, "1;7") : metaLine);

    // Named sessions (via /rename) get a star prefix and yellow highlight
    const displayText = session.customTitle
      ? "★ " + session.customTitle
      : session.firstMessage || "";
    moveTo(tty, msgRow, 1);
    clearLine(tty);
    tty.write(
      session.customTitle
        ? style(truncate("  " + displayText, W), "33")
        : style(truncate("  " + displayText, W), "2"),
    );
  }

  moveTo(tty, H - 1, 1);
  clearLine(tty);
  tty.write("─".repeat(W));

  moveTo(tty, H, 1);
  clearLine(tty);
  tty.write("↑↓ Navigate  ⏎ Preview  ⌫ Delete  Tab Filter  Esc Quit");
}

/**
 * Render the full-screen message preview for a session.
 *
 * @param {import('tty').WriteStream} tty
 * @param {{
 *   filtered: object[],
 *   cursor: number,
 *   previewScroll: number,
 *   termWidth: number,
 *   termHeight: number
 * }} state
 * @param {{ role: string, timestamp: string, text: string }[]} messages
 */
function renderPreview(tty, state, messages) {
  const { filtered, cursor, previewScroll, termWidth, termHeight } = state;
  const W = termWidth;
  const H = termHeight;
  const session = filtered[cursor] || {};
  const firstMsg = session.customTitle || session.firstMessage || "";

  tty.write("\x1b[H\x1b[2J");

  const rightHint = "Esc to go back";
  const leftLabel = truncate("Preview: " + firstMsg, W - rightHint.length - 1);
  moveTo(tty, 1, 1);
  clearLine(tty);
  tty.write(leftLabel + " ".repeat(Math.max(0, W - leftLabel.length - rightHint.length)) + rightHint);

  moveTo(tty, 2, 1);
  clearLine(tty);
  tty.write("─".repeat(W));

  const renderLines = [];
  for (const msg of messages) {
    let ts = "";
    if (msg.timestamp) {
      const isoMatch = msg.timestamp.match(/(\d{2})-(\d{2})T(\d{2}):(\d{2})/);
      ts = isoMatch
        ? `${isoMatch[1]}-${isoMatch[2]} ${isoMatch[3]}:${isoMatch[4]}`
        : msg.timestamp.slice(0, 16);
    }

    renderLines.push(
      msg.role === "user"
        ? style(`You (${ts}):`, "1")
        : style(`Assistant (${ts}):`, "36"),
    );

    const chunkW = W - 4;
    for (const tl of msg.text.split("\n")) {
      if (tl.length === 0) {
        renderLines.push("");
        continue;
      }
      let remaining = tl;
      while (remaining.length > 0) {
        renderLines.push("  " + truncate(remaining, chunkW));
        remaining = remaining.slice(chunkW);
      }
    }
    renderLines.push("");
  }

  const listH = H - 4;
  const scroll = previewScroll || 0;
  for (let i = 0; i < listH; i++) {
    const displayRow = 3 + i;
    moveTo(tty, displayRow, 1);
    clearLine(tty);
    const lineIdx = scroll + i;
    if (lineIdx < renderLines.length) tty.write(truncate(renderLines[lineIdx], W));
  }

  moveTo(tty, H - 1, 1);
  clearLine(tty);
  tty.write("─".repeat(W));

  moveTo(tty, H, 1);
  clearLine(tty);
  tty.write("↑↓/^U^D Scroll  Esc Back");
}

/**
 * Render a centered delete-confirmation dialog on top of the current screen.
 *
 * @param {import('tty').WriteStream} tty
 * @param {{ termWidth: number, termHeight: number }} state
 * @param {{ firstMessage: string, modified: Date, size: number, messageCount: number }} session
 */
function renderDeleteConfirm(tty, state, session) {
  const { termWidth, termHeight } = state;
  const BOX_W = 50;
  const BOX_H = 7;
  const startRow = Math.floor((termHeight - BOX_H) / 2);
  const startCol = Math.floor((termWidth - BOX_W) / 2);
  const innerW = BOX_W - 2;

  const d = session.modified instanceof Date ? session.modified : new Date(session.modified);
  const dateStr = `${String(d.getMonth() + 1).padStart(2, "0")}-${String(d.getDate()).padStart(2, "0")}`;

  function centerText(text) {
    const leftPad = Math.floor((innerW - text.length) / 2);
    const rightPad = innerW - text.length - leftPad;
    return " ".repeat(Math.max(0, leftPad)) + text + " ".repeat(Math.max(0, rightPad));
  }

  const contentLines = [
    style(centerText("Delete this session?"), "1"),
    centerText(""),
    style(centerText(truncate(`"${session.customTitle || session.firstMessage}"`, innerW)), "2"),
    centerText(`${dateStr}  ${formatSize(session.size)}  ${session.messageCount} messages`),
    centerText(""),
    centerText("[Y] Yes, delete    [N] No, cancel"),
  ];

  moveTo(tty, startRow, startCol);
  tty.write("┌" + "─".repeat(innerW) + "┐");

  for (let i = 0; i < contentLines.length; i++) {
    moveTo(tty, startRow + 1 + i, startCol);
    tty.write("│" + contentLines[i] + "│");
  }

  moveTo(tty, startRow + 1 + contentLines.length, startCol);
  tty.write("└" + "─".repeat(innerW) + "┘");
}

/**
 * Render a centered "No sessions found" message for an empty session list.
 *
 * @param {import('tty').WriteStream} tty
 * @param {{ termWidth: number, termHeight: number }} state
 */
function renderEmpty(tty, state) {
  const { termWidth, termHeight } = state;
  tty.write("\x1b[H\x1b[2J");

  const msg1 = "No sessions found";
  const msg2 = "Esc to quit";

  const row1 = Math.floor(termHeight / 2);
  moveTo(tty, row1, Math.floor((termWidth - msg1.length) / 2) + 1);
  clearLine(tty);
  tty.write(msg1);

  moveTo(tty, row1 + 1, Math.floor((termWidth - msg2.length) / 2) + 1);
  clearLine(tty);
  tty.write(style(msg2, "2"));
}

/**
 * Render the normal header/footer but a centered "No matches" in the list area.
 *
 * @param {import('tty').WriteStream} tty
 * @param {{
 *   filterLabel: string,
 *   termWidth: number,
 *   termHeight: number
 * }} state
 */
function renderNoMatches(tty, state) {
  const { filterLabel, termWidth, termHeight } = state;
  const W = termWidth;
  const H = termHeight;

  tty.write("\x1b[H\x1b[2J");

  const inSearch = filterLabel.includes("Search:");
  const rightHint = inSearch ? "" : "Type to search...";
  const leftPart = truncate(filterLabel, W);
  moveTo(tty, 1, 1);
  clearLine(tty);
  if (rightHint) {
    const padding = Math.max(0, W - leftPart.length - rightHint.length);
    tty.write(leftPart + " ".repeat(padding) + style(rightHint, "2"));
  } else {
    tty.write(leftPart);
  }

  moveTo(tty, 2, 1);
  clearLine(tty);
  tty.write("─".repeat(W));

  const listAreaMid = Math.floor((3 + H - 2) / 2);
  const noMatchText = "No matches";
  moveTo(tty, listAreaMid, Math.floor((W - noMatchText.length) / 2) + 1);
  tty.write(style(noMatchText, "2"));

  moveTo(tty, H - 1, 1);
  clearLine(tty);
  tty.write("─".repeat(W));

  moveTo(tty, H, 1);
  clearLine(tty);
  tty.write("↑↓ Navigate  ⏎ Preview  ⌫ Delete  Tab Filter  Esc Quit");
}

// ─────────────────────────────────────────────
// Interactive mode
// ─────────────────────────────────────────────

// Exported reference so tests can call applyFilter after runInteractive sets it
let _applyFilter = null;

/**
 * Handle a keypress while the session list is visible.
 *
 * Returns true if the key was handled.
 *
 * @param {string} key
 * @param {string|undefined} char
 * @param {object} state
 * @param {string[]} filterModes
 * @param {Function} applyFilter
 * @param {Function} render
 * @param {Function} cleanExit
 * @param {import('tty').WriteStream} ttyWriteStream
 * @returns {boolean}
 */
function handleListKey(key, char, state, filterModes, applyFilter, render, cleanExit, ttyWriteStream) {
  const viewportSize = Math.floor((state.termHeight - 4) / 2);

  if (key === "up") {
    if (state.cursor > 0) {
      state.cursor--;
      if (state.cursor < state.scrollOffset) state.scrollOffset = state.cursor;
    }
    render();
    return true;
  }

  if (key === "down") {
    if (state.cursor < state.filtered.length - 1) {
      state.cursor++;
      if (state.cursor >= state.scrollOffset + viewportSize) {
        state.scrollOffset = state.cursor - viewportSize + 1;
      }
    }
    render();
    return true;
  }

  if (key === "enter") {
    if (state.filtered.length > 0) {
      const session = state.filtered[state.cursor];
      state.previewMessages = parseMessages(session.filePath);
      state.previewScroll = 0;
      state.mode = "preview";
      render();
    }
    return true;
  }

  if (key === "backspace") {
    if (state.searchText) {
      state.searchText = state.searchText.slice(0, -1);
      applyFilter();
      state.cursor = 0;
      state.scrollOffset = 0;
      render();
    } else if (state.filtered.length > 0) {
      state.mode = "confirm";
      render();
      renderDeleteConfirm(ttyWriteStream, state, state.filtered[state.cursor]);
    }
    return true;
  }

  if (key === "tab") {
    state.filterModeIndex = (state.filterModeIndex + 1) % filterModes.length;
    state.searchText = "";
    applyFilter();
    state.cursor = 0;
    state.scrollOffset = 0;
    render();
    return true;
  }

  if (key === "esc") {
    if (state.searchText) {
      state.searchText = "";
      applyFilter();
      state.cursor = 0;
      state.scrollOffset = 0;
      render();
    } else {
      cleanExit();
    }
    return true;
  }

  if (key === "char") {
    state.searchText += char;
    applyFilter();
    state.cursor = 0;
    state.scrollOffset = 0;
    render();
    return true;
  }

  return false;
}

/**
 * Handle a keypress while the message preview is open.
 *
 * @param {string} key
 * @param {object} state
 * @param {Function} render
 * @returns {boolean}
 */
function handlePreviewKey(key, state, render) {
  const halfPage = Math.max(1, Math.floor((state.termHeight - 4) / 2));

  if (key === "up") {
    if (state.previewScroll > 0) {
      state.previewScroll--;
      render();
    }
    return true;
  }

  if (key === "down") {
    state.previewScroll++;
    render();
    return true;
  }

  if (key === "ctrl-u") {
    state.previewScroll = Math.max(0, state.previewScroll - halfPage);
    render();
    return true;
  }

  if (key === "ctrl-d") {
    state.previewScroll += halfPage;
    render();
    return true;
  }

  if (key === "esc") {
    state.mode = "list";
    state.previewScroll = 0;
    render();
    return true;
  }

  return false;
}

/**
 * Handle a keypress while the delete-confirmation dialog is open.
 *
 * @param {string} key
 * @param {string|undefined} char
 * @param {object} state
 * @param {string[]} deleted - Accumulator for deleted session IDs
 * @param {Function} applyFilter
 * @param {Function} render
 * @returns {boolean}
 */
function handleConfirmKey(key, char, state, deleted, applyFilter, render) {
  const isYes = key === "char" && (char === "y" || char === "Y");
  const isNo = (key === "char" && (char === "n" || char === "N")) || key === "esc";

  if (isYes) {
    const session = state.filtered[state.cursor];
    try {
      deleteSessionFiles(session);
      deleted.push(session.sessionId);
      state.sessions = state.sessions.filter((s) => s.sessionId !== session.sessionId);
      applyFilter();
      state.cursor = Math.min(state.cursor, Math.max(0, state.filtered.length - 1));
    } catch (_) {
      // Deletion failure is non-fatal; the session remains visible
    }
    state.mode = "list";
    render();
    return true;
  }

  if (isNo) {
    state.mode = "list";
    render();
    return true;
  }

  return false;
}

function runInteractive() {
  let ttyFd;
  try {
    ttyFd = fs.openSync("/dev/tty", "r+");
  } catch (_) {
    process.stdout.write(JSON.stringify({ mode: "cli", reason: "no-tty" }) + "\n");
    return;
  }

  const tty = require("tty");
  const ttyReadStream = new tty.ReadStream(ttyFd);
  const ttyWriteStream = new tty.WriteStream(ttyFd);

  try {
    ttyReadStream.setRawMode(true);
  } catch (_) {
    fs.closeSync(ttyFd);
    process.stdout.write(JSON.stringify({ mode: "cli", reason: "no-tty" }) + "\n");
    return;
  }

  const allSessions = scanSessions(PROJECTS_DIR);
  const deleted = [];

  const uniqueProjects = [...new Set(allSessions.map((s) => s.project))].sort();
  const filterModes = ["all", ...uniqueProjects.map((p) => "project:" + p), "small", "old"];

  const state = {
    sessions: allSessions,
    filtered: [...allSessions],
    cursor: 0,
    scrollOffset: 0,
    filterModeIndex: 0,
    searchText: "",
    mode: "list",
    previewScroll: 0,
    previewMessages: [],
    previewTotalLines: 0,
    termWidth: ttyWriteStream.columns || 80,
    termHeight: ttyWriteStream.rows || 24,
    filterLabel: `Sessions (${allSessions.length})`,
  };

  function applyFilter() {
    const { filtered, filterLabel } = applyFilterStandalone(
      state.sessions,
      filterModes,
      state.filterModeIndex,
      state.searchText,
    );
    state.filtered = filtered;
    state.cursor = Math.min(state.cursor, Math.max(0, filtered.length - 1));
    state.scrollOffset = Math.min(state.scrollOffset, Math.max(0, filtered.length - 1));
    state.filterLabel = filterLabel;
  }

  _applyFilter = applyFilter;

  function render() {
    if (state.sessions.length === 0) return renderEmpty(ttyWriteStream, state);
    if (state.mode === "list") {
      return state.filtered.length === 0
        ? renderNoMatches(ttyWriteStream, state)
        : renderList(ttyWriteStream, state);
    }
    if (state.mode === "preview") {
      return renderPreview(ttyWriteStream, state, state.previewMessages);
    }
    // confirm: renderDeleteConfirm is drawn as an overlay after renderList
  }

  function cleanExit() {
    exitAltScreen(ttyWriteStream);
    ttyReadStream.setRawMode(false);
    ttyReadStream.destroy();
    ttyWriteStream.destroy();
    process.stdout.write(
      JSON.stringify({ action: "exit", deleted, remaining: state.sessions.length }) + "\n",
    );
    process.exit(0);
  }

  process.on("SIGWINCH", () => {
    state.termWidth = ttyWriteStream.columns || 80;
    state.termHeight = ttyWriteStream.rows || 24;
    render();
  });

  function handleKey(key, char) {
    if (state.mode === "list") {
      handleListKey(key, char, state, filterModes, applyFilter, render, cleanExit, ttyWriteStream);
    } else if (state.mode === "preview") {
      handlePreviewKey(key, state, render);
    } else if (state.mode === "confirm") {
      handleConfirmKey(key, char, state, deleted, applyFilter, render);
    }
  }

  // Escape sequences arrive as multi-byte chunks; buffer them briefly to
  // distinguish a bare Esc keypress from arrow keys (which start with Esc).
  let escBuffer = "";
  let escTimer = null;

  ttyReadStream.on("data", (buf) => {
    const data = buf.toString("utf8");

    for (let i = 0; i < data.length; i++) {
      const ch = data[i];

      if (escBuffer) {
        escBuffer += ch;
        clearTimeout(escTimer);

        if (escBuffer === "\x1b[A") { handleKey("up"); escBuffer = ""; continue; }
        if (escBuffer === "\x1b[B") { handleKey("down"); escBuffer = ""; continue; }
        if (escBuffer.length >= 3) { escBuffer = ""; continue; }

        escTimer = setTimeout(() => {
          if (escBuffer === "\x1b") handleKey("esc");
          escBuffer = "";
        }, 50);
        continue;
      }

      if (ch === "\x1b") {
        escBuffer = "\x1b";
        escTimer = setTimeout(() => {
          if (escBuffer === "\x1b") handleKey("esc");
          escBuffer = "";
        }, 50);
        continue;
      }

      if (ch === "\r") { handleKey("enter"); continue; }
      if (ch === "\x7f") { handleKey("backspace"); continue; }
      if (ch === "\t") { handleKey("tab"); continue; }
      if (ch === "\x03") { cleanExit(); return; }
      if (ch === "\x15") { handleKey("ctrl-u"); continue; }
      if (ch === "\x04") { handleKey("ctrl-d"); continue; }

      const code = ch.charCodeAt(0);
      if (code >= 0x20 && code <= 0x7e) handleKey("char", ch);
    }
  });

  enterAltScreen(ttyWriteStream);
  render();
}

// ─────────────────────────────────────────────
// CLI subcommand handlers
// ─────────────────────────────────────────────

/**
 * Write a CLI error response to stdout and exit with code 1.
 *
 * @param {string} message
 */
function cliError(message) {
  process.stdout.write(JSON.stringify({ mode: "cli", error: message }) + "\n");
  process.exit(1);
}

/**
 * Validate that a session id is alphanumeric/hyphen/underscore and that
 * its resolved file path stays within PROJECTS_DIR.
 *
 * Returns the matched session object or calls cliError and exits.
 *
 * @param {string} id
 * @returns {object} session from scanSessions
 */
function resolveSessionOrExit(id) {
  if (!id || !/^[a-zA-Z0-9_-]+$/.test(id)) cliError(`Invalid session id: ${id}`);

  const resolvedProjects = path.resolve(PROJECTS_DIR);
  const sessions = scanSessions(PROJECTS_DIR);
  const session = sessions.find((s) => s.sessionId === id);

  if (!session) cliError(`Session not found: ${id}`);

  const resolvedFile = path.resolve(session.filePath);
  if (!resolvedFile.startsWith(resolvedProjects + path.sep)) {
    cliError(`Invalid session path: ${id}`);
  }

  return session;
}

function handleList() {
  const raw = scanSessions(PROJECTS_DIR);
  const sessions = raw.map((s) => ({
    id: s.sessionId,
    name: s.customTitle || null,
    project: s.project,
    modified: s.modified.toISOString().slice(0, 10),
    size: formatSize(s.size),
    messageCount: s.messageCount,
    firstMessage: s.firstMessage,
  }));
  process.stdout.write(JSON.stringify({ mode: "cli", sessions }) + "\n");
  process.exit(0);
}

function handlePreview(id) {
  const session = resolveSessionOrExit(id);
  const messages = parseMessages(session.filePath);
  process.stdout.write(JSON.stringify({ mode: "cli", sessionId: id, messages }) + "\n");
  process.exit(0);
}

function handleDelete(id) {
  const session = resolveSessionOrExit(id);
  try {
    deleteSessionFiles(session);
  } catch (err) {
    cliError(err.message);
  }
  const remaining = scanSessions(PROJECTS_DIR).length;
  process.stdout.write(JSON.stringify({ mode: "cli", deleted: id, remaining }) + "\n");
  process.exit(0);
}

/**
 * Handle --clean-auto: find and delete all auto-generated sessions in one shot.
 */
function handleCleanAuto() {
  const sessions = scanSessions(PROJECTS_DIR);
  const autoSessions = sessions.filter((s) => isAutoGenerated(s));

  if (autoSessions.length === 0) {
    process.stdout.write(
      JSON.stringify({
        mode: "cli",
        cleaned: 0,
        remaining: sessions.length,
        message: "No auto-generated sessions found.",
      }) + "\n",
    );
    process.exit(0);
  }

  const deleted = [];
  const failed = [];
  for (const session of autoSessions) {
    try {
      deleteSessionFiles(session);
      deleted.push(session.sessionId);
    } catch (_) {
      failed.push(session.sessionId);
    }
  }

  const remaining = sessions.length - deleted.length;
  const failNote = failed.length ? ` ${failed.length} failed to delete.` : "";
  process.stdout.write(
    JSON.stringify({
      mode: "cli",
      cleaned: deleted.length,
      remaining,
      deleted,
      ...(failed.length ? { failed } : {}),
      message: `Cleaned ${deleted.length} auto-generated session(s). ${remaining} remaining.${failNote}`,
    }) + "\n",
  );
  process.exit(0);
}

// ─────────────────────────────────────────────
// Exports (for testing)
// ─────────────────────────────────────────────

module.exports = {
  scanSessions,
  formatSize,
  applyFilterStandalone,
  listSessions,
  previewSession,
  deleteSession,
  hasTty,
  parseMessages,
  enterAltScreen,
  exitAltScreen,
  moveTo,
  clearLine,
  style,
  truncate,
  renderList,
  renderPreview,
  renderDeleteConfirm,
  renderEmpty,
  renderNoMatches,
  runInteractive,
  get applyFilter() {
    return _applyFilter;
  },
  isAutoGenerated,
  handleCleanAuto,
};

// ─────────────────────────────────────────────
// Main
// ─────────────────────────────────────────────

function main() {
  if (MODE_CLEAN_AUTO) return handleCleanAuto();
  if (MODE_LIST) return handleList();

  if (MODE_PREVIEW) {
    if (!PREVIEW_ID) {
      process.stderr.write("Error: --preview requires a session id\n");
      process.exit(1);
    }
    return handlePreview(PREVIEW_ID);
  }

  if (MODE_DELETE) {
    if (!DELETE_ID) {
      process.stderr.write("Error: --delete requires a session id\n");
      process.exit(1);
    }
    return handleDelete(DELETE_ID);
  }

  if (hasTty()) return runInteractive();

  // No TTY available — signal CLI fallback to the caller
  process.stdout.write(JSON.stringify({ mode: "cli", reason: "no-tty" }) + "\n");
  process.exit(0);
}

if (require.main === module) {
  main();
}
