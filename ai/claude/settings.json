{
  "permissions": {
    "allow": [
      "Bash(echo *)",
      "Bash(mkdir *)",
      "Bash(npm run build)",
      "Bash(npm run lint)",
      "Bash(npm run test)",
      "Bash(npm run test:*)",
      "Bash(npx vitest run:*)",
      "Edit(ai/memory/*)",
      "Edit(memory/*)",
      "WebFetch",
      "WebSearch"
    ],
    "deny": [],
    "ask": []
  },
  "statusLine": {
    "type": "command",
    "command": "$HOME/.config/ai/claude/statusline.sh"
  },
  "alwaysThinkingEnabled": true,
  "extraKnownMarketplaces": {
    "anthropic-agent-skills": {
      "source": {
        "source": "github",
        "repo": "anthropics/skills"
      }
    }
  }
}
